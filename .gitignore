# ══════════════════════════════════════════════════════════════
#  NeuroTutor — .gitignore
#  Django backend  +  React / Vite frontend monorepo
# ══════════════════════════════════════════════════════════════

# ── Python / Django ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST
.Python

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/

# Django migrations (keep these in VCS — comment out if you disagree)
# */migrations/

# Collected static files
staticfiles/
static_root/

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
nosetests.xml
test-results/

# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ── Environment / Secrets ─────────────────────────────────────
.env
.env.*
# always keep the example in VCS
!.env.example
!**/.env.example
*.pem
*.key
secrets.json

# ── Node / Vite / React ───────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# Vite cache
.vite/
vite.config.*.timestamp-*

# Build artefacts
build/
out/

# Parcel cache
.cache/
.parcel-cache/

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Lock files (keep package-lock.json / yarn.lock in VCS)
# package-lock.json
# yarn.lock

# ── AI / Vector DB ────────────────────────────────────────────
# ChromaDB persistent storage
chroma_db/
chroma/
*.chroma
.chromadb/
chromadb/

# Sentence-transformer model cache
sentence_transformers_cache/
.cache/huggingface/
models/

# ── Project-specific generated / temp files ──────────────────
# Test output dumps
test_output.txt
test_adaptive_output.txt
test_db_output.txt
test_integration_output*.txt
test_results.txt
migrate_output.txt
generation.log
ai_interactions.log

# Benchmark data
benchmarks/results/

# Temporary scripts / debug helpers
tmp/
debug_*.py
# always keep the proper tests/ directory
!tests/
!**/tests/

# ── Editors / IDEs ────────────────────────────────────────────
# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# Windsurf / AI coding agents
.windsurf/
.agent/
.agents/

# Vim / Emacs swapfiles
*.sw?
*~
\#*\#
.\#*

# ── OS ────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.suo
*.ntvs*
*.njsproj
*.sln

# Linux
*~

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.orig
*.rej
*.patch
