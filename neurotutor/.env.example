# NeuroTutor — Environment Variables
# Copy to .env and set values. NEVER commit .env.

# ── Required ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
SECRET_KEY=your_django_secret_key_here

# ── Production (required when deploying) ───────────────────────────────────────
# DJANGO_ENV=production
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Database ─────────────────────────────────────────────────────────────────
# Omit all DB_* for local SQLite. For production use PostgreSQL:
# DB_NAME=neurotutor
# DB_USER=neurotutor
# DB_PASSWORD=secure_password
# DB_HOST=localhost
# DB_PORT=5432

# ── Optional ─────────────────────────────────────────────────────────────────
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis (production: share rate-limit state across workers)
# REDIS_URL=redis://localhost:6379/0

# Log to file (optional; if unset, logs go to console only)
# LOG_FILE=logs/neurotutor.log
